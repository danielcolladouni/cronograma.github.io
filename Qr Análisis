<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Benner y Análisis – Estudio Ictus UI</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
  :root { --navy:#0B1F3A; --teal:#0D6E6E; --teal-lt:#1EB8B8; --gold:#C8A84B; --cream:#F0EDE6; --white:#FFF; --gray:#6B7A90; }
  * { box-sizing:border-box; margin:0; padding:0; }
  body { font-family:-apple-system,'Segoe UI',sans-serif; background:var(--cream); color:var(--navy); }
  .top-bar { height:5px; background:linear-gradient(90deg,var(--teal),var(--gold),var(--teal)); }
  .header { background:var(--navy); padding:24px 32px 20px; }
  .header-badge { display:inline-block; background:rgba(200,168,75,0.18); border:1px solid var(--gold); border-radius:4px; padding:4px 14px; font-size:11px; color:var(--gold); letter-spacing:2px; text-transform:uppercase; margin-bottom:12px; }
  .header h1 { font-size:22px; color:var(--white); line-height:1.3; margin-bottom:6px; }
  .header h1 em { color:var(--teal-lt); font-style:italic; }
  .header-sub { font-size:13px; color:rgba(255,255,255,0.55); }
  .divider-bar { height:3px; background:linear-gradient(90deg,var(--teal),var(--gold),var(--teal)); }
  .content { max-width:900px; margin:0 auto; padding:28px 20px 60px; }
  .section { margin-bottom:36px; }
  .section-title { font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); font-family:monospace; margin-bottom:16px; padding-bottom:8px; border-bottom:1px solid #dde2ea; }
  .chart-wrap { background:var(--white); border-radius:12px; padding:20px; box-shadow:0 2px 12px rgba(11,31,58,0.08); margin-bottom:16px; }
  .chart-title { font-size:14px; font-weight:700; color:var(--navy); margin-bottom:4px; }
  .chart-sub { font-size:12px; color:var(--gray); margin-bottom:16px; }

  .two-col { display:grid; grid-template-columns:1fr 1fr; gap:16px; }

  /* Benner cards */
  .benner-cards { display:flex; flex-direction:column; gap:8px; }
  .benner-card { display:flex; align-items:center; gap:12px; background:var(--white); border-radius:10px; padding:12px 16px; box-shadow:0 2px 8px rgba(11,31,58,0.07); }
  .benner-card.hl { border-left:3px solid var(--teal); }
  .b-num { width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; color:var(--white); flex-shrink:0; font-family:monospace; }
  .b-num.n { background:var(--navy); }
  .b-num.t { background:var(--teal); }
  .b-info { flex:1; }
  .b-lbl { font-size:14px; font-weight:700; color:var(--navy); }
  .b-desc { font-size:12px; color:var(--gray); margin-top:2px; line-height:1.4; }
  .b-bar-outer { height:6px; background:#eef1f5; border-radius:3px; margin-top:6px; overflow:hidden; }
  .b-bar-inner { height:100%; border-radius:3px; }

  /* Sample calculation */
  .calc-box { background:var(--white); border-radius:12px; padding:20px; box-shadow:0 2px 12px rgba(11,31,58,0.08); }
  .calc-title { font-size:14px; font-weight:700; color:var(--navy); margin-bottom:14px; }
  .calc-params { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:16px; }
  .calc-param { background:#eef1f5; border-radius:8px; padding:10px 12px; }
  .calc-param-lbl { font-size:10px; letter-spacing:1.5px; text-transform:uppercase; color:var(--gray); font-family:monospace; margin-bottom:3px; }
  .calc-param-val { font-size:18px; font-weight:700; color:var(--navy); }
  .calc-result { background:rgba(13,110,110,0.08); border:1px solid rgba(13,110,110,0.3); border-radius:8px; padding:12px 14px; }
  .calc-result-lbl { font-size:11px; color:var(--teal); text-transform:uppercase; letter-spacing:1px; font-family:monospace; margin-bottom:4px; }
  .calc-result-val { font-size:28px; font-weight:700; color:var(--teal); }
  .calc-result-sub { font-size:12px; color:var(--gray); margin-top:2px; }

  /* Analysis steps */
  .analysis-steps { display:flex; flex-direction:column; gap:10px; }
  .astep { background:var(--white); border-radius:10px; padding:14px 16px; box-shadow:0 2px 8px rgba(11,31,58,0.07); display:flex; gap:12px; }
  .astep-num { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; color:var(--white); flex-shrink:0; font-family:monospace; }
  .astep-body {}
  .astep-title { font-size:13px; font-weight:700; color:var(--navy); margin-bottom:3px; }
  .astep-desc { font-size:12px; color:var(--gray); line-height:1.5; }
  .astep-tools { margin-top:5px; display:flex; gap:5px; flex-wrap:wrap; }
  .tool-tag { font-size:10px; background:rgba(11,31,58,0.08); color:var(--navy); padding:2px 7px; border-radius:4px; font-family:monospace; font-weight:600; }

  .footer-band { background:var(--navy); padding:16px 32px; display:flex; justify-content:space-between; align-items:center; }
  .footer-band span { font-size:12px; color:rgba(255,255,255,0.5); }
  .footer-band strong { color:rgba(255,255,255,0.8); }
</style>
</head>
<body>
<div class="top-bar"></div>
<div class="header">
  <div class="header-badge">SEEIUC · Estudio Ictus</div>
  <h1>Modelo de Benner y Análisis Estadístico<br><em>Evaluación enfermería unidad de ictus</em></h1>
  <div class="header-sub">Daniel Collado Moreno (IP) · R / RStudio · REDCap v.2025 14.0.19 · p &lt; 0,05</div>
</div>
<div class="divider-bar"></div>

<div class="content">

  <div class="two-col" style="margin-bottom:24px;">
    <div class="section" style="margin-bottom:0;">
      <div class="section-title">Modelo de Patricia Benner (1984)</div>
      <div class="benner-cards">
        <div class="benner-card">
          <div class="b-num n">I</div>
          <div class="b-info">
            <div class="b-lbl">Principiante</div>
            <div class="b-desc">Sin experiencia; aplica reglas rígidas sin contextualizar</div>
            <div class="b-bar-outer"><div class="b-bar-inner" style="width:20%;background:#6B7A90;"></div></div>
          </div>
        </div>
        <div class="benner-card">
          <div class="b-num n">II</div>
          <div class="b-info">
            <div class="b-lbl">Principiante avanzada</div>
            <div class="b-desc">Reconoce patrones recurrentes en situaciones reales</div>
            <div class="b-bar-outer"><div class="b-bar-inner" style="width:40%;background:#1EB8B8;"></div></div>
          </div>
        </div>
        <div class="benner-card hl">
          <div class="b-num t">III</div>
          <div class="b-info">
            <div class="b-lbl">Competente</div>
            <div class="b-desc">Planifica y prioriza; mayor autonomía y seguridad</div>
            <div class="b-bar-outer"><div class="b-bar-inner" style="width:60%;background:#0D6E6E;"></div></div>
          </div>
        </div>
        <div class="benner-card hl">
          <div class="b-num t">IV</div>
          <div class="b-info">
            <div class="b-lbl">Eficiente</div>
            <div class="b-desc">Visión holística; ajusta planes ante situaciones cambiantes</div>
            <div class="b-bar-outer"><div class="b-bar-inner" style="width:80%;background:#0D6E6E;"></div></div>
          </div>
        </div>
        <div class="benner-card hl">
          <div class="b-num t">V</div>
          <div class="b-info">
            <div class="b-lbl">Experta</div>
            <div class="b-desc">Comprensión intuitiva; actúa sin razonamiento analítico</div>
            <div class="b-bar-outer"><div class="b-bar-inner" style="width:100%;background:#C8A84B;"></div></div>
          </div>
        </div>
      </div>
    </div>

    <div class="section" style="margin-bottom:0;">
      <div class="section-title">Cálculo Tamaño Muestral</div>
      <div class="calc-box">
        <div class="calc-title">Correlación de Pearson bilateral</div>
        <div class="calc-params">
          <div class="calc-param"><div class="calc-param-lbl">Coeficiente r</div><div class="calc-param-val">0,4</div></div>
          <div class="calc-param"><div class="calc-param-lbl">Nivel α (bilateral)</div><div class="calc-param-val">0,05</div></div>
          <div class="calc-param"><div class="calc-param-lbl">Poder estadístico</div><div class="calc-param-val">0,8</div></div>
          <div class="calc-param"><div class="calc-param-lbl">Tasa sustitución</div><div class="calc-param-val">0,3</div></div>
        </div>
        <div class="calc-result">
          <div class="calc-result-lbl">Mínimo requerido</div>
          <div class="calc-result-val">67 enfermeras</div>
          <div class="calc-result-sub">De un total de 120 disponibles (tasa participación &gt;55%)</div>
        </div>
      </div>

      <div style="margin-top:14px;">
        <div class="chart-wrap">
          <div class="chart-title">Distribución esperada nivel Benner</div>
          <div class="chart-sub">Distribución hipotética de la muestra según nivel autopercibido</div>
          <canvas id="bennerChart" height="160"></canvas>
        </div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Plan de Análisis Estadístico — Detalle</div>
    <div class="analysis-steps">
      <div class="astep">
        <div class="astep-num" style="background:#0B1F3A">1</div>
        <div class="astep-body">
          <div class="astep-title">Análisis Descriptivo</div>
          <div class="astep-desc">Media, mediana y desviación estándar para variables cuantitativas. Frecuencias absolutas y proporciones para variables cualitativas. Presentación en tablas y gráficos. Detección de valores perdidos.</div>
          <div class="astep-tools"><span class="tool-tag">R base</span><span class="tool-tag">ggplot2</span><span class="tool-tag">summary()</span></div>
        </div>
      </div>
      <div class="astep">
        <div class="astep-num" style="background:#1EB8B8">2</div>
        <div class="astep-body">
          <div class="astep-title">Pruebas de Normalidad</div>
          <div class="astep-desc">Test de Shapiro-Wilk para muestras pequeñas o medianas. Test de Kolmogorov-Smirnov para muestras grandes. Los resultados determinan el uso de pruebas paramétricas o no paramétricas.</div>
          <div class="astep-tools"><span class="tool-tag">shapiro.test()</span><span class="tool-tag">ks.test()</span></div>
        </div>
      </div>
      <div class="astep">
        <div class="astep-num" style="background:#0D6E6E">3</div>
        <div class="astep-body">
          <div class="astep-title">Análisis de Clústers</div>
          <div class="astep-desc">Conglomerados jerárquico con distancia euclídea/Manhattan y enlazamiento Ward.D2. Análisis de mezclas gaussianas con mclust. Selección del modelo óptimo mediante índice de silueta y BIC (Bayesian Information Criterion).</div>
          <div class="astep-tools"><span class="tool-tag">hclust()</span><span class="tool-tag">mclust</span><span class="tool-tag">cluster</span><span class="tool-tag">factoextra</span></div>
        </div>
      </div>
      <div class="astep">
        <div class="astep-num" style="background:#C8A84B">4</div>
        <div class="astep-body">
          <div class="astep-title">Análisis Inferencial Correlacional</div>
          <div class="astep-desc">Correlación entre autopercepción de pericia (Benner) y desempeño clínico observado (ítems CRD). Nivel de significancia p &lt; 0,05 para todos los análisis.</div>
          <div class="astep-tools"><span class="tool-tag">cor.test()</span><span class="tool-tag">Pearson/Spearman</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Correlación esperada — Hipótesis del estudio</div>
    <div class="chart-wrap">
      <canvas id="corrChart" height="200"></canvas>
    </div>
  </div>

</div>

<div class="footer-band">
  <span><strong>Estudio Ictus UI</strong> · Benner P. (1984). From novice to expert.</span>
  <span>Hospital nivel B · Provincia de Barcelona · CEIC aprobado</span>
</div>

<script>
// Benner distribution chart
const bCtx = document.getElementById('bennerChart').getContext('2d');
new Chart(bCtx, {
  type: 'bar',
  data: {
    labels: ['I Principiante','II Princ. avanzada','III Competente','IV Eficiente','V Experta'],
    datasets: [{
      label: 'Nº enfermeras esperadas',
      data: [8, 22, 38, 32, 20],
      backgroundColor: ['#6B7A90','#1EB8B8','#0D6E6E','#0D6E6E','#C8A84B'],
      borderRadius: 6,
    }]
  },
  options: {
    responsive: true,
    plugins: { legend:{display:false}, tooltip:{ callbacks:{ label:(c)=>`~${c.raw} enfermeras` } } },
    scales: {
      x: { ticks:{font:{size:10},color:'#0B1F3A'} },
      y: { beginAtZero:true, ticks:{font:{size:10},color:'#6B7A90'}, title:{display:true,text:'Nº esperado',font:{size:10}} }
    }
  }
});

// Correlation scatter simulation
const corrCtx = document.getElementById('corrChart').getContext('2d');
const scatter = [];
for (let i=0; i<80; i++) {
  const x = Math.random()*4+1;
  const y = x * 1.8 + (Math.random()-0.5)*3 + Math.random()*2;
  scatter.push({x: Math.round(x*10)/10, y: Math.min(10,Math.max(0,Math.round(y*10)/10))});
}
new Chart(corrCtx, {
  type: 'scatter',
  data: {
    datasets: [
      {
        label: 'Enfermera observada',
        data: scatter,
        backgroundColor: 'rgba(13,110,110,0.5)',
        pointRadius: 5,
      },
      {
        label: 'Tendencia esperada (H2)',
        data: [{x:1,y:2},{x:2,y:4},{x:3,y:6},{x:4,y:8},{x:5,y:10}],
        type: 'line',
        borderColor: '#C8A84B',
        borderWidth: 2,
        borderDash: [6,4],
        pointRadius: 0,
        fill: false,
      }
    ]
  },
  options: {
    responsive: true,
    plugins: { legend:{ labels:{font:{size:11},color:'#0B1F3A'} } },
    scales: {
      x: { title:{display:true,text:'Nivel Benner autopercibido (1-5)',font:{size:11}}, ticks:{color:'#0B1F3A'} },
      y: { title:{display:true,text:'Cumplimiento ítems práctica clínica (0-10)',font:{size:11}}, ticks:{color:'#0B1F3A'}, beginAtZero:true }
    }
  }
});
</script>
</body>
</html>
